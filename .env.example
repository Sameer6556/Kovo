# ============================================================
#  Kovo — client (React) environment variables
#  Copy this file to `.env` and fill in your own value.
#  NEVER commit your real .env file.
# ============================================================

# Base URL of the backend API.
# Local development:
#   REACT_APP_BASE_URL=http://localhost:4000/api/v1
# Production (point to your deployed backend):
#   REACT_APP_BASE_URL=https://your-backend-host.com/api/v1
REACT_APP_BASE_URL=http://localhost:4000/api/v1

# Razorpay public Key ID (the "rzp_test_..." / "rzp_live_..." key — NOT the secret).
# Safe to expose on the frontend; used to open the Razorpay checkout.
REACT_APP_RAZORPAY_KEY=
