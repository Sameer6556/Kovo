# ============================================================
#  Kovo — server environment variables
#  Copy this file to `.env` and fill in your own values.
#  NEVER commit your real .env file.
# ============================================================

# Port the API server listens on
PORT=4000

# Public URL of the deployed frontend — used in email links & password reset.
# Local:      http://localhost:3000
# Production: https://your-frontend.vercel.app   (no trailing slash)
FRONTEND_URL=http://localhost:3000

# --- Database ---
# MongoDB Atlas (or local) connection string
MONGODB_URL=

# --- Auth ---
# Secret used to sign / verify JSON Web Tokens
JWT_SECRET=

# --- Mail — sends OTP & notification emails via the Brevo API (over HTTPS) ---
# BREVO_API_KEY: from Brevo → Settings → SMTP & API → API Keys
# MAIL_USER: the "from" address — must be a VERIFIED sender in Brevo
BREVO_API_KEY=
MAIL_USER=
# (MAIL_HOST / MAIL_PASS are no longer used, kept for reference)
MAIL_HOST=smtp.gmail.com
MAIL_PASS=

# --- Cloudinary — stores media (thumbnails, videos, images) ---
CLOUD_NAME=
API_KEY=
API_SECRET=
FOLDER_NAME=Profile

# --- Razorpay — payments ---
RAZORPAY_KEY=
RAZORPAY_SECRET=
